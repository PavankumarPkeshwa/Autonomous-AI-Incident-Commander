# Environment Configuration Template for AWS Deployment
# Copy this file to .env and fill in your actual values

# ==============================================================================
# LOCAL DEVELOPMENT
# ==============================================================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ==============================================================================
# LLM Configuration (Groq)
# ==============================================================================
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# ==============================================================================
# API Configuration
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS Configuration - Set to your frontend domain
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "https://your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ==============================================================================
# Frontend Configuration
# ==============================================================================
FRONTEND_URL=http://localhost:5173
FRONTEND_S3_BUCKET=incident-commander-frontend-staging

# ==============================================================================
# AWS Configuration (For production deployment)
# ==============================================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ECR Configuration
ECR_REPOSITORY=incident-commander-backend
ECR_IMAGE_TAG=latest

# ECS Configuration
ECS_CLUSTER=incident-commander
ECS_SERVICE=incident-commander-api
ECS_TASK_FAMILY=incident-commander-backend

# CloudWatch Configuration
CLOUDWATCH_LOG_GROUP=/ecs/incident-commander
CLOUDWATCH_NAMESPACE=IncidentCommander

# ==============================================================================
# Database Configuration (if using RDS or DynamoDB)
# ==============================================================================
# DynamoDB
DYNAMODB_REGION=us-east-1
DYNAMODB_INCIDENT_TABLE=incident-commander-incidents
DYNAMODB_AUDIT_TABLE=incident-commander-audit

# RDS (PostgreSQL)
# RDS_HOST=your-db-instance.xxxxx.us-east-1.rds.amazonaws.com
# RDS_PORT=5432
# RDS_DATABASE=incident_commander
# RDS_USER=postgres
# RDS_PASSWORD=your_secure_password_here

# ==============================================================================
# Secrets Manager Configuration
# ==============================================================================
SECRETS_MANAGER_REGION=us-east-1
SECRETS_MANAGER_SECRET_NAME=incident-commander/groq-key

# ==============================================================================
# Application Settings
# ==============================================================================
# Incident Response Configuration
MAX_PARALLEL_AGENTS=4
INCIDENT_TIMEOUT_SECONDS=300
LOG_SEARCH_LIMIT=1000
METRICS_QUERY_LIMIT=500

# Rollback Configuration
AUTO_ROLLBACK_ENABLED=false
ROLLBACK_TIMEOUT_SECONDS=120
REQUIRE_APPROVAL_FOR_ROLLBACK=true

# ==============================================================================
# Monitoring & Alerting
# ==============================================================================
ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:incident-alerts
ALERT_EMAIL=on-call@yourcompany.com
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==============================================================================
# Feature Flags
# ==============================================================================
FEATURE_AUTO_REMEDIATION=false
FEATURE_RCA_GENERATION=true
FEATURE_DEPLOYMENT_ANALYSIS=true
FEATURE_METRICS_ANALYSIS=true
FEATURE_LOG_ANALYSIS=true

# ==============================================================================
# Security
# ==============================================================================
# API Key for authenticated requests (optional)
API_KEY=your_api_key_here

# JWT Configuration (if implementing JWT)
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_FORMAT=json  # Options: json, text
LOG_OUTPUT=both  # Options: console, file, both
LOG_FILE_PATH=/var/log/incident-commander/app.log
LOG_RETENTION_DAYS=30

# ==============================================================================
# Cache Configuration
# ==============================================================================
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_BACKEND=in-memory  # Options: in-memory, redis

# Redis configuration (if using Redis cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0

# ==============================================================================
# Performance Tuning
# ==============================================================================
# Connection pooling
CONNECTION_POOL_SIZE=20
CONNECTION_POOL_OVERFLOW=10

# Request timeout
REQUEST_TIMEOUT_SECONDS=30

# Batch processing
BATCH_SIZE=100

# ==============================================================================
# Development/Testing Only
# ==============================================================================
# Mock data mode (for testing without real Groq API)
MOCK_MODE=false

# Enable request/response logging
LOG_REQUESTS=false
LOG_RESPONSES=false

# Database initialization
# INIT_DB=true
# SEED_SAMPLE_DATA=true

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
# 
# 1. SENSITIVE VALUES:
#    - Store GROQ_API_KEY in AWS Secrets Manager, not in this file
#    - Never commit .env files to version control
#    - Use .env.example for template reference
#
# 2. ENVIRONMENT-SPECIFIC:
#    - Create separate .env.staging and .env.production
#    - Use environment variables for AWS Lambda deployment
#    - Use Secrets Manager for sensitive data
#
# 3. VALIDATION:
#    - Ensure all required fields are filled before deployment
#    - Test .env file with: python -m dotenv -p show
#    - Validate CORS origins match your frontend domain
#
# 4. DOCKER DEPLOYMENT:
#    - Pass environment variables to 'docker run' command
#    - Use --env-file flag: docker run --env-file .env myimage
#
# 5. KUBERNETES DEPLOYMENT:
#    - Create ConfigMap for non-sensitive configuration
#    - Create Secret for sensitive data
#    - Reference in pod spec
#
# 6. AWS ECS DEPLOYMENT:
#    - Store secrets in AWS Secrets Manager
#    - Pass non-secret config via ECS task environment
#    - Reference secrets with valueFrom in task definition
#
# ==============================================================================
